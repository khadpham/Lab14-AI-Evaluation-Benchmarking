# AI Evaluation Factory - Environment Variables
# Copy this file to .env and fill in your API keys

# ===========================================
# GROQ API (for LLM - Agent & Judge)
# Get key at: https://console.groq.com/keys
# ===========================================
GROQ_API_KEY=your_groq_api_key_here

# ===========================================
# OPENAI API (backup / alternative LLM)
# Get key at: https://platform.openai.com/api-keys
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# ANTHROPIC API (for Claude Judge)
# Get key at: https://console.anthropic.com/settings/keys
# ===========================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# GOOGLE AI API (for Gemini Judge)
# Get key at: https://aistudio.google.com/app/apikey
# ===========================================
GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# Configuration
# ===========================================
# Embedding model to use (default: Vietnamese embedding)
EMBEDDING_MODEL=dangvantuan/vietnamese-embedding

# Vector DB persistence path
VECTOR_DB_PATH=data/vector_db/chroma_db

# ChromaDB collection name
CHROMA_COLLECTION_NAME=evaluation_docs

# Default LLM for Agent (groq, openai, anthropic)
AGENT_LLM_PROVIDER=groq

# LLM model for Agent (using Groq)
AGENT_LLM_MODEL=qwen/qwen3-32b

# Judge models (comma-separated)
JUDGE_MODELS=gemini-2.5-flash,grok-3-beta,qwen-3-32b